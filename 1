-- ==== TRAIN DESPAWN TIMING ====
-- Cargo & passenger trains run the fixed world track (TRACK centerline above, cum = studs from the cargo START). Both
-- move ~67.5 st/s and despawn when their marker reaches the far end. We read the server-bound RobberyMarker (named
-- TrainCargo / TrainPassenger -- present even before the train mesh streams in), project it onto the centerline ->
-- remaining distance -> ETA. Cargo despawns at the END (remaining = TRACK_LEN - cum); passenger runs the reverse and
-- despawns at the START (remaining = cum). Coords are identical on every server, so this works the instant we join.
local TRAIN_SPEED = 67.5
local TRAIN_OFF_MAX = 30 -- marker farther than this from the line -> projection untrusted (timing approximate)

local function projTrack(px, py, pz)
	local bestD, bestCum = math.huge, 0
	for i = 2, #TRACK do
		local a, b = TRACK[i - 1], TRACK[i]
		local abx, aby, abz = b[1] - a[1], b[2] - a[2], b[3] - a[3]
		local abl = abx * abx + aby * aby + abz * abz
		local t = 0
		if abl > 0 then t = ((px - a[1]) * abx + (py - a[2]) * aby + (pz - a[3]) * abz) / abl end
		if t < 0 then t = 0 elseif t > 1 then t = 1 end
		local dx, dy, dz = a[1] + abx * t - px, a[2] + aby * t - py, a[3] + abz * t - pz
		local d = dx * dx + dy * dy + dz * dz
		if d < bestD then bestD, bestCum = d, a[4] + (b[4] - a[4]) * t end
	end
	return bestCum, math.sqrt(bestD)
end

local function trainMarkerPos(name)
	for _, m in ipairs(CollectionService:GetTagged("RobberyMarker")) do
		if m.Name == name then
			if m:IsA("BasePart") then return m.Position end
			if m:IsA("Model") then local ok, cf = pcall(function() return m:GetPivot() end); if ok then return cf.Position end end
		end
	end
	return nil
end

local function oneTrain(name, remainOf)
	local pos = trainMarkerPos(name)
	if not pos then return nil end
	local cum, off = projTrack(pos.X, pos.Y, pos.Z)
	local secs = math.max(0, remainOf(cum)) / TRAIN_SPEED
	return {
		present = true,
		secondsUntilDespawn = secs,
		despawnAt = os.time() + math.floor(secs + 0.5),
		offPath = off,
		timingApprox = (off > TRAIN_OFF_MAX) or nil,
		progress = math.clamp(cum / TRACK_LEN, 0, 1), -- physical position along the track (same frame set for both trains)
	}
end

local function trainReport()
	local cargo = oneTrain("TrainCargo", function(cum) return TRACK_LEN - cum end)
	local passenger = oneTrain("TrainPassenger", function(cum) return cum end)
	if not cargo and not passenger then return nil end
	return { cargo = cargo, passenger = passenger }
end

-- ==== STATIONARY ROBBERY COUNTDOWN ====
-- Each robbery ships its own <Marker>RobberyConsts ModuleScript: TIMEOUT_PERIOD (how long it stays OPEN) + the NAME of
-- a "status changed at" attribute (a stamp set when it last opened). closesAt = StatusChangedAt + TIMEOUT_PERIOD.
local robConsts = {}    -- markerBase ("Tomb") -> { timeout, changedAttr, statusAttr }
local nameToMarker = {} -- enum name ("TOMB") -> markerBase ("Tomb")
local function buildRobConsts()
	if Consts and Consts.DATA_ROBBERY then
		for id, data in pairs(Consts.DATA_ROBBERY) do
			local nm = idToName[id]
			if nm and type(data) == "table" and data.markerName then nameToMarker[nm] = data.markerName end
		end
	end
	for _, m in ipairs(RS:GetDescendants()) do
		if m:IsA("ModuleScript") and m.Name ~= "RobberyConsts" and m.Name:match("RobberyConsts$") then
			local c = req(m)
			if type(c) == "table" and (c.TIMEOUT_PERIOD or c.STATUS_CHANGED_AT_ATTR_NAME) then
				robConsts[(m.Name:gsub("RobberyConsts$", ""))] =
					{ timeout = c.TIMEOUT_PERIOD, changedAttr = c.STATUS_CHANGED_AT_ATTR_NAME, statusAttr = c.STATUS_ATTR_NAME }
			end
		end
	end
end
local function readAttrAnywhere(id, base, attr)
	local folder = stateFolderName and RS:FindFirstChild(stateFolderName)
	local sv = folder and id and folder:FindFirstChild(tostring(id))
	local v
	if sv then v = sv:GetAttribute(attr); if type(v) == "number" then return v, "state" end end
	if folder then v = folder:GetAttribute(attr); if type(v) == "number" then return v, "folder" end end
	if base then
		for _, mk in ipairs(CollectionService:GetTagged("RobberyMarker")) do
			if mk.Name == base then v = mk:GetAttribute(attr); if type(v) == "number" then return v, "marker" end end
		end
	end
	return nil
end
-- secondsLeft, closesAtUnix, debugSrc  (nil if we can't time it -> robbery reported status-only)
local function stationaryTiming(name)
	local base = nameToMarker[name]
	local rc = base and robConsts[base]
	if not (rc and rc.timeout and rc.changedAttr) then return nil end
	local id = Consts and Consts.ENUM_ROBBERY and Consts.ENUM_ROBBERY[name]
	local stamp, src = readAttrAnywhere(id, base, rc.changedAttr)
	if not stamp then return nil end
	-- stamp may be unix (~1.7e9) or a workspace clock; measure elapsed in whichever matches its magnitude
	local elapsed = (stamp > 1e9) and (os.time() - stamp) or (nowSync() - stamp)
	local left = math.max(0, rc.timeout - elapsed)
	return left, os.time() + math.floor(left + 0.5), (src or "?") .. "/" .. base
end

