	local st = readStates()
	if activeState(st, "CARGO_PLANE") and not findPlaneModel() then return false end
	if activeState(st, "TRAIN_CARGO") and not trainMarkerPos("TrainCargo") then return false end
	if activeState(st, "TRAIN_PASSENGER") and not trainMarkerPos("TrainPassenger") then return false end
	return true
end
local function prefetchServers() task.spawn(function() pcall(getServers) end) end

-- autoexec runs BEFORE RobberyState values replicate (they arrive CLOSED, then flip), so an early read finds only 1-2
-- robberies. Wait until every state child is present AND the whole value-set holds steady for a few reads = settled.
local function stateSignature()
	local folder = stateFolderName and RS:FindFirstChild(stateFolderName)
	if not folder then return nil, 0 end
	local kids = folder:GetChildren()
	local parts = {}
	for _, v in ipairs(kids) do
		local ok, val = pcall(function() return v.Value end)
		parts[#parts + 1] = v.Name .. "=" .. tostring(ok and val or "?")
	end
	table.sort(parts)
	return table.concat(parts, ","), #kids
end
local function waitForStableState()
	local t0 = os.clock()
	local last, stable = nil, 0
	local want = expectedStateCount() -- 16 once Consts loaded; 0 -> rely on signature stability alone
	repeat
		task.wait(0.15)
		local sig, n = stateSignature()
		if sig and n > 0 and n >= want then
			if sig == last then stable += 1 else stable = 0 end
			last = sig
		end
	until stable >= 2 or (os.clock() - t0 > CONFIG.SettleSec)
end

-- the scanner is one-shot-per-server (autoexec re-runs after each teleport), so it MUST always end in a hop. beginHop
-- guarantees exactly one initial hop whether the scan finished, errored, or hung.
local hopStarted = false
local function beginHop()
	if hopStarted then return end
	hopStarted = true
	if CONFIG.Hop then serverHop() end
end

task.spawn(function()
	local arrivedAt = os.clock()
	-- WATCHDOG: if the scan ever hangs (game never loads, state never settles, plane stream stuck), force a hop so the
	-- autoexec chain can NEVER dead-end on one server. A normal scan finishes well under this.
	task.delay(math.max(45, CONFIG.MinSecPerServer + 5), function()
		if not hopStarted then warn("[ROBSCAN] watchdog: scan stalled -> forcing hop") beginHop() end
	end)
	-- whole scan in a pcall: ANY error must still let us hop (a dead thread = the "script just stops" bug)
	local ok, err = pcall(function()
		if not game:IsLoaded() then game.Loaded:Wait() end -- autoexec fires before the game loads; wait or everything is half-ready
		-- on autoexec the script-load loadConsts() ran before RobberyConsts replicated (Consts=nil -> empty idToName, nil
		-- stateFolderName, statusWord prints raw numbers = "finds 1 robbery / acts wrong"). Retry until it resolves.
		local lc0 = os.clock()
		while not loadConsts() and os.clock() - lc0 < 10 do task.wait(0.2) end
		loadPlaneFlight()
		buildRobConsts()
		if not planeOffsets then warn("[ROBSCAN] no cargo flight data â€” state-only") end
		prefetchServers() -- warm the server-list file cache during settle so the hop fires with no fetch latency
		waitForStableState() -- autoexec scans before values replicate -> "only 1 robbery"; wait for the full state to settle
		markArrived()
		-- plane streaming is OFF by default (RequestStreamAroundAsync + camera = top executor-crash risk on arrival)
		if planeOffsets and CONFIG.StreamPlane then
			local st = readStates()
			if activeState(st, "CARGO_PLANE") and not findPlaneModel() then
				focusPlaneStream()
				local s0 = os.clock()
				repeat task.wait(0.1) until scanReady() or (os.clock() - s0 > CONFIG.StreamWait)
			end
		end
		local snap = snapshot()
		_G.__robscan.latest = snap
		if CONFIG.DebugPrint then print(debugLine(snap)) end
		reportBot(snap) -- the ONLY output: POST the live robbery states to the Discord bot
	end)
	if not ok then warn("[ROBSCAN] scan error -> hopping anyway: " .. tostring(err)) end
	-- pace the hop: stay >= MinSecPerServer so we teleport LESS often (every teleport risks the executor not re-attaching)
	while os.clock() - arrivedAt < CONFIG.MinSecPerServer and not hopStarted do task.wait(0.5) end
	beginHop()
end)
