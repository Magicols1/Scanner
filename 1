-- ==== HELPERS ====
local function child(root, ...)
	local node = root
	for _, seg in ipairs({ ... }) do
		if not node then return nil end
		node = node:FindFirstChild(seg)
	end
	return node
end
local function req(inst)
	if not inst then return nil end
	local ok, m = pcall(require, inst)
	return ok and m or nil
end
local function shuffle(t)
	for i = #t, 2, -1 do
		local j = math.random(i)
		t[i], t[j] = t[j], t[i]
	end
end

local Consts, Time, PlaneShared -- required LAZILY (autoexec runs before these replicate); (re)loaded by loadConsts()
local httpFn = (syn and syn.request) or http_request or request or (http and http.request) or (fluxus and fluxus.request)

local function nowSync()
	if Time and Time.GetNowSync then
		local ok, t = pcall(Time.GetNowSync)
		if ok and t then return t end
	end
	return os.clock()
end

