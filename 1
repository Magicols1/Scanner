local function brainPut(tbl)
	if not (httpFn and CONFIG.BrainUrl ~= "") then return end
	local ok, res = send(CONFIG.BrainPutMethod, CONFIG.BrainUrl, HttpService:JSONEncode(tbl), CONFIG.BrainHeaders)
