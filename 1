-- ==== SERVER HOP ====
local serverCache = {}  -- fetched once, reused across many hops; visited filter (brain.v) drains it -> re-fetch only when empty
local function fetchServers()
	if not httpFn then return {} end
	-- preferred: through the Worker (Cloudflare caches the list -> no per-scout Roblox 429)
	if CONFIG.ServersUrl ~= "" then
		local ok, res = pcall(httpFn, { Url = CONFIG.ServersUrl .. "?placeId=" .. game.PlaceId, Method = "GET", Headers = CONFIG.BrainHeaders })
		if ok and type(res) == "table" then
			local code = statusOf(res)
			if code and code ~= 200 then warn("[ROBSCAN] /servers status " .. tostring(code)) end
			if res.Body then
				local okd, d = pcall(function() return HttpService:JSONDecode(res.Body) end)
				if okd and d and d.data then return d.data end
			end
		end
		return {}
	end
	-- fallback: direct Roblox API (rate-limited; we cache the result so we only call this once per ~300 hops)
	local all, cursor = {}, nil
	for _ = 1, 5 do
		local url = ("https://games.roblox.com/v1/games/%d/servers/Public?limit=100&excludeFullGames=true"):format(game.PlaceId)
			.. (cursor and ("&cursor=" .. cursor) or "")
		local ok, res = pcall(httpFn, {
			Url = url, Method = "GET",
			Headers = { ["User-Agent"] = "Roblox/WinInet", ["Accept"] = "application/json" },
		})
		if not ok or type(res) ~= "table" or not res.Body then break end
		local code = statusOf(res)
		if code == 429 then warn("[ROBSCAN] Roblox API 429 (list cached for reuse; set CONFIG.ServersUrl to avoid)") task.wait(10) break end
		if code and code ~= 200 then break end
		local okd, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
		if not okd or not data or not data.data then break end
		for _, s in ipairs(data.data) do table.insert(all, s) end
		cursor = data.nextPageCursor
		if not cursor then break end
	end
	return all
end
local SERVERS_FILE = "robscan_servers.json"
local SERVERS_TTL = 300 -- reuse a fetched server list this many seconds ACROSS hops (each hop is a fresh process)
local function readServersFile()
	if not (isfile and readfile and isfile(SERVERS_FILE)) then return nil end
	local ok, d = pcall(function() return HttpService:JSONDecode(readfile(SERVERS_FILE)) end)
	if ok and type(d) == "table" and type(d.data) == "table" and tonumber(d.fetchedAt)
		and (os.time() - d.fetchedAt) < SERVERS_TTL and #d.data > 0 then
		return d.data
	end
	return nil
end
local function getServers()
	if #serverCache > 0 then return serverCache end
	local cached = readServersFile()
	if cached then serverCache = cached; return serverCache end -- fresh list on disk -> no Roblox call, instant pick
	serverCache = fetchServers() or {}
	if #serverCache > 0 and writefile then
		pcall(function() writefile(SERVERS_FILE, HttpService:JSONEncode({ fetchedAt = os.time(), data = serverCache })) end)
	end
	return serverCache
end
local function stopRequested()
	return CONFIG.StopFile ~= "" and isfile and isfile(CONFIG.StopFile)
end
local _queued = false
local function persist()
	if _queued or not QOT then return end  -- queue the re-loader ONCE per run (the guard dedups any extras anyway)
	_queued = true
	if CONFIG.SelfUrl == "" then
		if CONFIG.SelfSource ~= "" then pcall(queue_on_teleport, CONFIG.SelfSource) end
		return
	end
	-- Re-loader queued for the next arrival. It prefers a FRESH LOCAL CACHE (so 5 bots don't hammer raw.githubusercontent
	-- -> 429), only refetches when the cache is stale, and falls back to the cache if a fetch ever fails -> the self-rerun
	-- chain survives GitHub/network blips. Cache is per-account so the 5 don't clobber each other.
	local cache = "robscan_self_" .. tostring(LP.UserId) .. ".lua"
	local loader = ([==[
local u,c,tsf=%q,%q,%q..".ts"
local s,fresh
if isfile and isfile(c) and isfile(tsf) then
	local t=tonumber(readfile(tsf)) or 0
	if os.time()-t<600 then s=readfile(c); fresh=true end
end
if not fresh then
	local ok,r=pcall(function() return game:HttpGet(u) end)
	if ok and type(r)=="string" and #r>200 then s=r; pcall(function() writefile(c,r); writefile(tsf,tostring(os.time())) end)
	elseif isfile and isfile(c) then s=readfile(c) end
end
if s then local f=loadstring(s); if f then f() end end
]==]):format(CONFIG.SelfUrl, cache, cache)
	local ok = pcall(QOT, loader)
	if CONFIG.DebugPrint then print("[ROBSCAN] queued self-reloader for next hop: " .. tostring(ok)) end
end
local function serverHop(depth)
	depth = depth or 0
	if stopRequested() then warn("[ROBSCAN] stop file present â€” staying put") return end
	if depth > 8 then warn("[ROBSCAN] hop exhausted â€” pausing 20s") task.wait(20) end
	persist()
	local now = os.time()
	local useBrain = CONFIG.BrainUrl ~= ""
	local brain = useBrain and pruneBrain(brainGet() or {}) or { v = localVisited(), c = {} }
	brain.v[game.JobId] = now + CONFIG.RevisitCooldown
	brain.c[game.JobId] = nil

	-- fetch the server list; retry rather than ever matchmaking (matchmaking groups scouts together)
	local servers
	for attempt = 1, 4 do
		servers = getServers()
		if #servers > 0 then break end
		warn("[ROBSCAN] server list empty (attempt " .. attempt .. ") â€” retrying")
		task.wait(3)
	end
	servers = servers or {}
	shuffle(servers)
	local pick
	for _, s in ipairs(servers) do
		if s.id and s.id ~= game.JobId and not brain.v[s.id] and not brain.c[s.id]
			and s.playing and s.maxPlayers and s.playing < s.maxPlayers then
			pick = s.id
			break
		end
	end
	if pick then brain.c[pick] = now + CONFIG.ClaimTTL end
	if useBrain then brainPut(brain) else saveLocalVisited(brain.v) end
	if CONFIG.DebugPrint then print(("[ROBSCAN] hop: servers=%d pick=%s"):format(#servers, tostring(pick))) end

	if not pick then
		serverCache = {}  -- list exhausted / all visited -> force a fresh pull next hop
		if delfile and isfile and isfile(SERVERS_FILE) then pcall(delfile, SERVERS_FILE) end
		if depth >= 2 and not useBrain then
			saveLocalVisited({})  -- the cooldown list is filtering out everything -> wipe it so we ALWAYS find a server (never deadlock)
			warn("[ROBSCAN] every server filtered -> cleared visited cooldown")
		end
		warn("[ROBSCAN] no eligible server â€” retrying")
		task.wait(2)
		return serverHop(depth + 1)
	end
	if _G.__robscan then _G.__robscan._running = false end  -- release the guard BEFORE teleporting so the next server's autoexec run isn't blocked by a persisted _G
	local okT = pcall(function() TeleportService:TeleportToPlaceInstance(game.PlaceId, pick, LP) end)
	if not okT then
		task.wait(2)
		return serverHop(depth + 1)
	end
end

