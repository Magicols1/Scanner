		for jid, exp in pairs(data) do if tonumber(exp) and exp > now then out[jid] = exp end end
	end
	return out
end
local VISIT_MAX = 20  -- it's only a short relog cooldown; keep just the N newest JobIds so the list can NEVER grow until it filters out every server (= hop deadlock)
local function saveLocalVisited(v)
	local arr = {}
	for jid, exp in pairs(v) do arr[#arr + 1] = { jid, exp } end
	if #arr > VISIT_MAX then
		table.sort(arr, function(a, b) return a[2] > b[2] end)  -- newest expiry first
		v = {}
		for i = 1, VISIT_MAX do v[arr[i][1]] = arr[i][2] end
	end
	if writefile then pcall(function() writefile(VISIT_FILE, HttpService:JSONEncode(v)) end) end
end
local function statusOf(res)
	return type(res) == "table" and (res.StatusCode or res.Status or res.status_code) or nil
end
local function brainGet()
	if not (httpFn and CONFIG.BrainUrl ~= "") then return nil end
