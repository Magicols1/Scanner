-- how many state children we expect once fully replicated = number of robberies; fills in after loadConsts succeeds
-- (0 while Consts is still missing -> the settle loop falls back to signature-stability alone)
local function expectedStateCount()
	local n = 0
	for _ in pairs(idToName) do n += 1 end
	return n
end
local function statusWord(v)
	if not Consts then return tostring(v) end
	local E = Consts.ENUM_STATUS
	if v == E.OPENED then return "open"
	elseif v == E.STARTED then return "in_progress"
	elseif v == E.CLOSED then return "closed"
	else return "unknown" end
end
local function readStates()
	local out = {}
	local folder = stateFolderName and RS:FindFirstChild(stateFolderName)
	if not folder then return out end
	for _, v in ipairs(folder:GetChildren()) do
		local id = tonumber(v.Name)
		local name = (id and idToName[id]) or v.Name
		local ok, val = pcall(function() return v.Value end)
		out[name] = ok and statusWord(val) or "unknown"
	end
	return out
end
local function canReadState()
	return Consts ~= nil and stateFolderName ~= nil and RS:FindFirstChild(stateFolderName) ~= nil
end

-- ==== CARGO PLANE FLIGHT TIMING ====
local planeOffsets, planePaths
local function loadPlaneFlight()
	if not (PlaneShared and PlaneShared.GetFlightData) then return end
	local ok, fd = pcall(PlaneShared.GetFlightData)
	if not ok or not fd or type(fd.SeqsLayout) ~= "table" then return end
	local t, marks = 0, {}
	for _, seq in ipairs(fd.SeqsLayout) do
		marks[seq[1]] = { start = t, dur = seq[2] }
		t += seq[2]
	end
	local enter, leave = marks.SeqEnter, marks.SeqLeave
	planeOffsets = {
		arrival = enter and (enter.start + enter.dur) or nil,
		ePrompts = leave and (leave.start + 0.2 * leave.dur) or nil,
		depart = leave and leave.start or nil,
		despawn = t,
	}
	if fd.PathEnter and fd.PathLeave and enter and leave then
		pcall(function() fd.PathEnter.ApproxTotalLength = fd.PathEnter:ApproximateLength(1000) end)
		pcall(function() fd.PathLeave.ApproxTotalLength = fd.PathLeave:ApproximateLength(1000) end)
		planePaths = { enter = fd.PathEnter, leave = fd.PathLeave,
			enterStart = enter.start, enterDur = enter.dur, leaveStart = leave.start, leaveDur = leave.dur }
	end
end

local cargo = { bornAt = nil, bornAtKnown = false }
local function findPlaneModel()
	for _, inst in ipairs(CollectionService:GetTagged("RobberyMarker")) do
		if inst.Name == "CargoPlane" then
			local m = inst.Parent
			if m and m:IsA("Model") and m.PrimaryPart then return m end
			if inst:IsA("BasePart") then return inst end
		end
	end
	return nil
end
local function easedToLinear(v)
	v = math.clamp(v, 0, 1)
	return (math.asin(math.clamp(2 * v - 1, -1, 1)) + math.pi / 2) / math.pi
end
local function nearestFrac(path, pos, samples)
	local bestF, bestD = 0, math.huge
	local len = path.ApproxTotalLength or path:ApproximateLength(1000)
	for i = 0, samples do
		local f = i / samples
		local ok, p = pcall(function() return (path:GetWorldPositionAt(len * f)) end)
		if ok and p then
			local d = (p - pos).Magnitude
			if d < bestD then bestD, bestF = d, f end
		end
	end
	return bestF, bestD
end
local function estimateBornAt()
	if not planePaths then return end
	local model = findPlaneModel()
	local part = model and (model.PrimaryPart or (model:IsA("BasePart") and model) or model:FindFirstChildWhichIsA("BasePart"))
	if not part then return end
	local pos = part.Position
	local ef, ed = nearestFrac(planePaths.enter, pos, 120)
	local lf, ld = nearestFrac(planePaths.leave, pos, 120)
	local now = nowSync()
	if ed <= ld and ed < 60 then
		cargo.bornAt = now - (planePaths.enterStart + easedToLinear(ef) * planePaths.enterDur)
		cargo.bornAtKnown = true
	elseif ld < 60 then
		cargo.bornAt = now - (planePaths.leaveStart + easedToLinear(lf) * planePaths.leaveDur)
		cargo.bornAtKnown = true
	else
		cargo.bornAtKnown = false
	end
end

-- ==== CARGO PLANE STATUS (Open once e-prompts have appeared) ====
local function planeReport(states)
	local st = states.CARGO_PLANE or "closed"
	local r = { state = st }
	if st == "closed" then
		cargo.bornAt, cargo.bornAtKnown = nil, false
		return r
	end
	if not cargo.bornAt then estimateBornAt() end
	if cargo.bornAt and planeOffsets then
		local el = nowSync() - cargo.bornAt
		local nowU = os.time()
		local function rem(off) return off and math.max(0, off - el) or nil end
		local function at(off) local s = rem(off); return s and (nowU + math.floor(s + 0.5)) or nil end
		r.bornAtKnown = cargo.bornAtKnown
		r.secondsUntilEPrompts = rem(planeOffsets.ePrompts)
		r.secondsUntilDespawn = rem(planeOffsets.despawn)
		r.ePromptsAt = at(planeOffsets.ePrompts)
		r.arrivalAt = at(planeOffsets.arrival)   -- absolute unix the plane finishes arriving at the airport (bot: "still inbound" cutoff)
		r.departsAt = at(planeOffsets.depart)
			r.despawnAt = at(planeOffsets.despawn)
		-- Open once e-prompts are up, until despawn
		r.robbableNow = (planeOffsets.ePrompts ~= nil and el >= planeOffsets.ePrompts
			and planeOffsets.despawn ~= nil and el < planeOffsets.despawn) or false
		r.progress = planeOffsets.despawn and math.clamp(el / planeOffsets.despawn, 0, 1) or nil -- 0..1 over the flight (for the map frame picker)
	else
		r.bornAtKnown = false
	end
	return r
end

