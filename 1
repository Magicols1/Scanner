end
local function pruneBrain(b)
	local now = os.time()
	b.v = b.v or {}
	b.c = b.c or {}
	for j, e in pairs(b.v) do if not (tonumber(e) and e > now) then b.v[j] = nil end end
	for j, e in pairs(b.c) do if not (tonumber(e) and e > now) then b.c[j] = nil end end
	return b
end
-- on arrival: mark this server visited + clear our claim, so other scouts skip it
local function markArrived()
	local now = os.time()
	if CONFIG.BrainUrl ~= "" then
		local b = pruneBrain(brainGet() or {})
		b.v[game.JobId] = now + CONFIG.RevisitCooldown
		b.c[game.JobId] = nil
