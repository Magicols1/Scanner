local VISIT_FILE = "robscan_visited_" .. tostring(LP.UserId) .. ".json"  -- per-account: 5 scouts on one PC must NOT write the same file (corrupts it -> hop fails)
local function localVisited()
	if not (isfile and readfile and isfile(VISIT_FILE)) then return {} end
	local ok, data = pcall(function() return HttpService:JSONDecode(readfile(VISIT_FILE)) end)
	local out, now = {}, os.time()
