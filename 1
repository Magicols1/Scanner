-- ==== BOT REPORT (the ONLY output: POST the live robbery states to the Discord bot) ====
local TRAIN_DUR = TRACK_LEN / TRAIN_SPEED
local SKIP_IN_LOOP = { CARGO_PLANE = true, TRAIN_CARGO = true, TRAIN_PASSENGER = true, CARGO_SHIP = true }
local function reportBot(snap)
	if not (httpFn and CONFIG.BotUrl ~= "") then return end
	local list = {}
	-- moving robberies carry startedAt (when the route began) + endsAt (despawn); the bot picks the synced gif from these
	local c = snap.cargoPlane
	if c and (c.state == "open" or c.state == "in_progress") and c.despawnAt and planeOffsets then
		list[#list + 1] = { name = "CARGO_PLANE", status = c.robbableNow and "open" or "in_progress",
			startedAt = c.despawnAt - math.floor(planeOffsets.despawn + 0.5), endsAt = c.despawnAt, arrivesAt = c.arrivalAt, departsAt = c.departsAt }
	end
	if snap.trains then
		local tc, tp = snap.trains.cargo, snap.trains.passenger
		if tc and tc.despawnAt then list[#list + 1] = { name = "TRAIN_CARGO", status = "in_progress",
			startedAt = tc.despawnAt - math.floor(TRAIN_DUR + 0.5), endsAt = tc.despawnAt } end
		if tp and tp.despawnAt then list[#list + 1] = { name = "TRAIN_PASSENGER", status = "in_progress",
			startedAt = tp.despawnAt - math.floor(TRAIN_DUR + 0.5), endsAt = tp.despawnAt } end
	end
	-- stationary robberies: attach endsAt from each one's TIMEOUT_PERIOD + StatusChangedAt (stationaryTiming); status-only if untimed
	for name, stt in pairs(snap.robberies) do
		if (stt == "open" or stt == "in_progress") and not SKIP_IN_LOOP[name] then
			local entry = { name = name, status = stt }
			local left, endsAt, src = stationaryTiming(name)
			if endsAt then
				entry.endsAt = endsAt
				if CONFIG.DebugPrint then print(("[ROBSCAN] timer %s: %ds left (closes %d) src=%s"):format(name, math.floor(left), endsAt, tostring(src))) end
			end
			list[#list + 1] = entry
		end
	end
	if #list == 0 then return end
	local body = HttpService:JSONEncode({
		token = CONFIG.RobberyToken, jobId = snap.jobId, placeId = snap.placeId,
		players = snap.players, maxPlayers = snap.maxPlayers, ts = snap.ts, robberies = list,
	})
	local ok, res = send("POST", CONFIG.BotUrl, body)
	local code = (type(res) == "table" and (res.StatusCode or res.Status)) or (ok and "?" or tostring(res))
	if CONFIG.DebugPrint then print(("[ROBSCAN] -> bot: %d robberies | ok=%s http=%s"):format(#list, tostring(ok), tostring(code))) end
end

